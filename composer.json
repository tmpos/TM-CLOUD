{
    "name": "tmpbase/tmpbase",
    "description": "A lightweight private backend platform powered by PHP and SQLite.",
    "type": "project",
    "require": {
        "php": "^8.1",
        "ext-fileinfo": "*",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "flightphp/core": "^3.15",
        "cboden/ratchet": "^0.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
